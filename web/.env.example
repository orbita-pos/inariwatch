# Database (Neon free tier — https://neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth (generate secret with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-here"
# In production, must point to the app subdomain:
# NEXTAUTH_URL="https://app.yourdomain.com"
NEXTAUTH_URL="http://localhost:3000"

# Subdomain routing (set in production only)
# NEXT_PUBLIC_ROOT_DOMAIN="yourdomain.com"
# → app.yourdomain.com  = login + dashboard
# → yourdomain.com      = marketing landing page

# GitHub OAuth for login (https://github.com/settings/applications/new)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# AES-256-GCM encryption key for sensitive DB fields (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=""

# CRON job protection secret (generate with: openssl rand -base64 32)
CRON_SECRET=""

# ── Optional: OAuth providers ──────────────────────────────────────────────

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitLab OAuth (https://gitlab.com/-/user_settings/applications)
GITLAB_CLIENT_ID=""
GITLAB_CLIENT_SECRET=""

# ── Optional: Email notifications ─────────────────────────────────────────

SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="InariWatch <noreply@yourdomain.com>"

# Email rate limits (per user)
EMAIL_RATE_LIMIT_HOURLY="10"
EMAIL_RATE_LIMIT_DAILY="50"
EMAIL_RATE_LIMIT_GLOBAL_DAILY="1000"

# ── Optional: Push notifications (Web Push / VAPID) ───────────────────────
# Generate with: npx web-push generate-vapid-keys

VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:admin@yourdomain.com"

# ── Optional: Stripe billing ──────────────────────────────────────────────

STRIPE_SECRET_KEY=""
STRIPE_PRO_PRICE_ID=""
STRIPE_TEAM_PRICE_ID=""
STRIPE_WEBHOOK_SECRET=""

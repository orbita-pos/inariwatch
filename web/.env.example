# =============================================================================
# InariWatch — Environment Variables
# Copy this file to .env.local and fill in your values.
#
# Quick start:
#   cp .env.example .env.local
#   # Required: DATABASE_URL, NEXTAUTH_SECRET, ENCRYPTION_KEY
#   # Everything else is optional — features are disabled if not set
# =============================================================================


# -----------------------------------------------------------------------------
# DATABASE (required)
# Postgres-compatible. Recommended: Neon free tier at https://neon.tech
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"


# -----------------------------------------------------------------------------
# AUTH (required)
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
# NEXTAUTH_URL = your full public URL, no trailing slash
# -----------------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# Subdomain routing (production only)
# app.yourdomain.com  = dashboard
# yourdomain.com      = marketing / landing
# NEXT_PUBLIC_ROOT_DOMAIN="yourdomain.com"


# -----------------------------------------------------------------------------
# ENCRYPTION (required)
# AES-256-GCM key for storing integration secrets in the database.
# Generate with: openssl rand -hex 32
# WARNING: Changing this key will make existing encrypted values unreadable.
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=""


# -----------------------------------------------------------------------------
# CRON (required in production)
# Authenticates Vercel cron calls to /api/cron/*
# Generate with: openssl rand -hex 16
# Set the same value in vercel.json under cron job headers.
# -----------------------------------------------------------------------------
CRON_SECRET=""


# -----------------------------------------------------------------------------
# EMAIL — SMTP (optional, enables email notifications + invites)
#
# Gmail:
#   SMTP_HOST=smtp.gmail.com  PORT=587  SECURE=false
#   SMTP_PASS = App Password (myaccount.google.com/apppasswords)
#
# Resend (recommended for production — https://resend.com):
#   SMTP_HOST=smtp.resend.com  PORT=465  SECURE=true
#   SMTP_USER=resend  SMTP_PASS=re_your_api_key
#
# Postmark, Mailgun, SendGrid also work with SMTP credentials.
# -----------------------------------------------------------------------------
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="InariWatch <alerts@yourdomain.com>"

# Email rate limits (per user per period)
EMAIL_RATE_LIMIT_HOURLY="10"
EMAIL_RATE_LIMIT_DAILY="50"
EMAIL_RATE_LIMIT_GLOBAL_DAILY="1000"

# AWS SES bounce/complaint webhook secret (optional)
# SES_WEBHOOK_SECRET=""


# -----------------------------------------------------------------------------
# PUSH NOTIFICATIONS — Web Push / VAPID (optional)
# Generate keys with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_ prefix required for the public key (used in browser)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:admin@yourdomain.com"


# -----------------------------------------------------------------------------
# OAUTH — Social Login (optional)
# Callback URL pattern: {NEXTAUTH_URL}/api/auth/callback/{provider}
#
# GitHub:  github.com/settings/developers → New OAuth App
# Google:  console.cloud.google.com → Credentials → OAuth 2.0
# GitLab:  gitlab.com/-/user_settings/applications
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

GITLAB_CLIENT_ID=""
GITLAB_CLIENT_SECRET=""


# -----------------------------------------------------------------------------
# ADMIN (optional)
# Email address of the super-admin user. Grants access to /admin panel.
# -----------------------------------------------------------------------------
# ADMIN_EMAIL="you@example.com"


# -----------------------------------------------------------------------------
# STRIPE (optional — Stripe is not required, the app runs fully free)
# Only needed if you re-enable paid plans.
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PRO_PRICE_ID="price_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."


# -----------------------------------------------------------------------------
# TESTING (never set in production)
# -----------------------------------------------------------------------------
# PLAYWRIGHT_BASE_URL="http://localhost:3000"
# TEST_USER_EMAIL="test@example.com"
# TEST_USER_PASSWORD="testpassword123"
